# Travis CI Environment Variables Template
# Copy these to your Travis CI repository settings

# Basic configuration
CI=true
NODE_ENV=test

# Docker configuration
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1

# Application configuration
REACT_APP_ENV=test
REACT_APP_API_URL=https://api-staging.your-domain.com

# Build configuration
BUILD_PARALLEL=true
GENERATE_SOURCEMAP=false

# Deployment configuration (add these as encrypted variables in Travis)
# DOCKER_USERNAME=your-docker-username
# DOCKER_PASSWORD=your-docker-password
# STAGING_SERVER=staging.your-domain.com
# PRODUCTION_SERVER=your-domain.com
# DEPLOY_USER=deploy-user
# DEPLOY_KEY=ssh-private-key-content
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# MONITORING_API_KEY=your-monitoring-api-key

# Cloud provider credentials (if using)
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_DEFAULT_REGION=us-west-2
# HEROKU_API_KEY=your-heroku-api-key
# GOOGLE_APPLICATION_CREDENTIALS=service-account-key.json
